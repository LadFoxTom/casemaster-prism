  }

  main.mig-shell {
    max-width: 1100px;
    margin: 0;
    padding: 0 2.25rem 5rem;
  }
  @media (max-width: 980px) {
    .mig-hero, main.mig-shell { padding-left: 1.25rem; padding-right: 1.25rem; }
  }

  .mig-section {
    margin: 3rem 0;
  }
