  }
  .mig-section .lead-2 {
    color: var(--muted);
    margin: 0 0 1.5rem;
    max-width: 760px;
  }

  .mig-checklist {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    box-shadow: var(--shadow);
    counter-reset: c;
    list-style: none;
    margin: 0;
  }
  .mig-checklist li {
    counter-increment: c;
    padding: 0.65rem 0 0.65rem 2.5rem;
    border-top: 1px solid var(--border);
    position: relative;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .mig-checklist li:first-child { border-top: 0; }
  .mig-checklist li::before {
    content: counter(c);
    position: absolute;
    left: 0;
    top: 0.7rem;
    width: 1.6rem;
    height: 1.6rem;
    background: var(--surface-2);
    color: var(--muted);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 700;
  }
  .mig-checklist li strong { color: var(--text); }

  .mig-diff {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  @media (max-width: 720px) { .mig-diff { grid-template-columns: 1fr; } }
  .mig-diff-pane {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .mig-diff-label {
    background: var(--surface-2);
    border-bottom: 1px solid var(--border);
    padding: 0.6rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
